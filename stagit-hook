set -e

log() {
	echo "$(basename "$0"): $@" 1>&2
}

err() {
	log "$@"
	exit 1
}

# This should be more flexible, but it works for now.
hooked() (
	cd "$repodir"
	find . -mindepth 2 -maxdepth 2 -type f |
	    awk -vn="$hasfile" -F/ '$NF == n {print $2}' |
		while read -r dir
	do
		git --git-dir "$dir" show -s --format="%ct	$dir" ||
			err "$dir: Unable to get repo information"
	done | sort -rn | cut -f2- | sed "i\\
${repodir%/}/"
)

outdated() (
	IFS='
'
	cd "$basedir"
	find . -mindepth 2 -maxdepth 2 -type f -name log.html | cut -d/ -f2 |
	    awk -vb="$basedir" '
BEGIN {
	for (i = 1; i <= ARGC; ++i) {
		split(ARGV[i], a, "/")
		valids[a[length(a)]] = 1
		delete ARGV[i]
	}
	ARGC = 0
}
!($0 in valids) { print b "/" $0 }' $hooked
)

clean() (
	IFS='
'
	rm -rf $(outdated)
	test -z "$hooked" &&
		rm -f "$index"
	return 0
)

loadfile() {
	case "$1" in
	(link) ;;
	(copy) link=false ;;
	(*) err "$1: link or copy"
	esac
	test "$2" -ef "$3" ||
	    ${link:-ln -f "$2" "$3"} ||
	    cat "$2" > "$3"
}

loadstyle() {
	c="${1:?requried}"
	s="$2"
	d="${3:-.}"

	for f in style.css logo.png favicon.png
	do
		loadfile "$c" "$s/$f" "$d/$f"
	done
}

index() (
	IFS='
'
	test -n "$styledir" && loadstyle copy "$styledir" "$basedir"
	test -n "$hooked" &&
		stagit-index $hooked > "$index"
)

repo() {
	abs="$(readlink -f "$1")"
	nam="$(basename "$abs")"
	dir="$basedir"/"$nam" 
	mkdir -p "$dir"
	cd "$dir"
	if stagit -u "$baseurl" "$abs"
	then
		test -n "$styledir" && loadstyle link ..
	else
		rmdir "$dir" 2>/dev/null
	fi
}

loadconfig() {
	test -f "$rc" ||
	    rc="${rc%.conf}"
	if test -f "$rc"
	then
		while read -r key val
		do
			case $key in
			('#'*|'') continue ;;
			(basedir) basedir="$val" ;;
			(baseurl) baseurl="$val" ;;
			(repodir) repodir="$val" ;;
			(hasfile) hasfile="$val" ;;
			(styledir) styledir="$val" ;;
			(*) err "$key: Invalid configuration"
			esac
		done < "$rc"
	fi
}

rc=/etc/stagit-hook.conf
host="$(hostname)"
baseurl=https://"$host"/projects/
repodir="$HOME"
hasfile=refs

loadconfig

while test $# -gt 0
do
	case "$1" in
	(-b|-basedir) basedir="${2:?-basedir: Requires an argument}"; shift ;;
	(-u|-baseurl) baseurl="${2:?-baseurl: Requires an argument}"; shift ;;
	(-r|-repodir) repodir="${2:?-repodir: Requires an argument}"; shift ;;
	(-p|-hasfile) hasfile="${2:?-hasfile: Requires an argument}"; shift ;;
	(-s|-styledir) styledir="${2:?-styledir: Requires an argument}"; shift ;;
	(--) break ;;
	(-*) err "$1: Invalid option
usage: stagit-hook [-b basedir] [-u baseurl] [-r repodir] [-p hasfile] [-s styledir] [repo ...]" ;;
	(*) break ;;
	esac
	shift
done

test -n "$basedir" ||
	err 'basedir: Base directory undefined'

test $# -eq 0 -a -n "$GIT_DIR" &&
    set -- "$GIT_DIR"

index="$basedir"/index.html
hooked="$(hooked)"

clean
index
for d in "$@"
do
	repo "$d" || {
		status=$?
		log "$d: Unable to generate"
	}
done

exit $status
